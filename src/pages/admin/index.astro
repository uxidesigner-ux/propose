---
import BaseLayout from '../../layouts/BaseLayout.astro';
import seedReport from '../../content/reports/q1-market-outlook.json';
---
<BaseLayout title="Admin" description="Static report admin">
  <section class="container admin">
    <h1>Report Builder (GitHub-only MVP)</h1>
    <p>Create and edit report JSON, then commit it to <code>src/content/reports/</code>.</p>
    <div class="grid two">
      <textarea id="editor" rows="24"></textarea>
      <div><h2>Preview</h2><div id="preview" class="card"></div></div>
    </div>
    <div class="row"><button class="btn" id="load">Load Sample</button><button class="btn" id="save">Save Draft</button><button class="btn" id="export">Export JSON</button><label class="btn" for="import-file">Import JSON</label><input id="import-file" type="file" hidden accept="application/json" /></div>
    <p>Publishing path: export JSON → place in <code>src/content/reports/&lt;slug&gt;.json</code> → commit/push → GitHub Pages deploy.</p>
  </section>
</BaseLayout>

<script define:vars={{ seedReport }} is:inline>
  const seed = JSON.parse(JSON.stringify(seedReport));
  const storageKey = 'report-draft-v1';

  const editor = document.getElementById('editor');
  const preview = document.getElementById('preview');
  const loadBtn = document.getElementById('load');
  const saveBtn = document.getElementById('save');
  const exportBtn = document.getElementById('export');
  const importInput = document.getElementById('import-file');

  const safeArray = (value) => Array.isArray(value) ? value : [];

  const renderPreview = () => {
    if (!(editor instanceof HTMLTextAreaElement)) return;
    if (!(preview instanceof HTMLDivElement)) return;

    try {
      const data = JSON.parse(editor.value);
      const blocks = safeArray(data.blocks);

      const items = blocks.map((block, index) => {
        const blockType = block && block.type ? block.type : 'unknown';
        const blockTitle = block && block.title ? ` — ${block.title}` : '';
        return `<li><strong>${index + 1}. ${blockType}</strong>${blockTitle}</li>`;
      }).join('');

      preview.innerHTML = `
        <div class="preview-card">
          <p class="preview-label">Slug</p>
          <p>${data.slug || 'n/a'}</p>
        </div>
        <div class="preview-card">
          <p class="preview-label">Title</p>
          <p>${data.title || 'Untitled report'}</p>
        </div>
        <div class="preview-card">
          <p class="preview-label">Blocks</p>
          <p>${blocks.length}</p>
        </div>
        <div class="preview-card preview-blocks">
          <p class="preview-label">Block List</p>
          <ol>${items || '<li>No blocks found</li>'}</ol>
        </div>
      `;
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Unknown error';
      preview.innerHTML = `<p class="preview-error">Invalid JSON: ${message}</p>`;
    }
  };

  if (loadBtn instanceof HTMLButtonElement && editor instanceof HTMLTextAreaElement) {
    loadBtn.addEventListener('click', () => {
      editor.value = JSON.stringify(seed, null, 2);
      renderPreview();
    });
  }

  if (saveBtn instanceof HTMLButtonElement && editor instanceof HTMLTextAreaElement) {
    saveBtn.addEventListener('click', () => {
      localStorage.setItem(storageKey, editor.value);
      alert('Draft saved to localStorage.');
    });
  }

  if (exportBtn instanceof HTMLButtonElement && editor instanceof HTMLTextAreaElement) {
    exportBtn.addEventListener('click', () => {
      const blob = new Blob([editor.value], { type: 'application/json' });
      const link = document.createElement('a');
      let filename = 'report.json';

      try {
        const parsed = JSON.parse(editor.value);
        if (parsed && parsed.slug) filename = `${parsed.slug}.json`;
      } catch (_) {}

      link.href = URL.createObjectURL(blob);
      link.download = filename;
      link.click();
      URL.revokeObjectURL(link.href);
    });
  }

  if (importInput instanceof HTMLInputElement && editor instanceof HTMLTextAreaElement) {
    importInput.addEventListener('change', async (event) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLInputElement)) return;

      const file = target.files && target.files[0];
      if (!file) return;

      editor.value = await file.text();
      renderPreview();
      target.value = '';
    });
  }

  if (editor instanceof HTMLTextAreaElement) {
    editor.addEventListener('input', renderPreview);
    editor.value = localStorage.getItem(storageKey) || JSON.stringify(seed, null, 2);
    renderPreview();
  }
</script>
