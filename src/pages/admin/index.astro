---
import BaseLayout from '../../layouts/BaseLayout.astro';
import seedReport from '../../content/reports/q1-market-outlook.json';
---
<BaseLayout title="Admin" description="Static report admin">
  <section class="container admin">
    <h1>Report Builder (GitHub-only MVP)</h1>
    <p>Create and edit report JSON, then commit it to <code>src/content/reports/</code>.</p>
    <div class="grid two">
      <textarea id="editor" rows="24"></textarea>
      <div><h2>Preview</h2><div id="preview" class="card"></div></div>
    </div>
    <div class="row"><button class="btn" id="load">Load Sample</button><button class="btn" id="save">Save Draft</button><button class="btn" id="export">Export JSON</button><label class="btn" for="import-file">Import JSON</label><input id="import-file" type="file" hidden accept="application/json" /></div>
    <p>Publishing path: export JSON → place in <code>src/content/reports/&lt;slug&gt;.json</code> → commit/push → GitHub Pages deploy.</p>
  </section>
</BaseLayout>

<script define:vars={{ seedReport }}>
  import { renderReportBlocks, validateChartBlock } from '../../lib/reportRenderer';

  type ReportBlock = {
    type: string;
    [key: string]: unknown;
  };

  type ReportData = {
    slug?: string;
    title?: string;
    blocks?: ReportBlock[];
    [key: string]: unknown;
  };

  const seed: ReportData = structuredClone(seedReport);
  const key = 'report-draft-v1';

  const editor = document.getElementById('editor') as HTMLTextAreaElement | null;
  const preview = document.getElementById('preview') as HTMLDivElement | null;
  const loadBtn = document.getElementById('load') as HTMLButtonElement | null;
  const saveBtn = document.getElementById('save') as HTMLButtonElement | null;
  const exportBtn = document.getElementById('export') as HTMLButtonElement | null;
  const importInput = document.getElementById('import-file') as HTMLInputElement | null;

  if (
    !editor ||
    !preview ||
    !loadBtn ||
    !saveBtn ||
    !exportBtn ||
    !importInput
  ) {
    throw new Error('Admin UI elements are missing.');
  }

  const render = () => {
    try {
      const data = JSON.parse(editor.value) as ReportData;
      const blocks = Array.isArray(data.blocks) ? data.blocks : [];

      const chartErrors = blocks
        .filter((block: ReportBlock) => block.type === 'chart')
        .flatMap((block: ReportBlock) => validateChartBlock(block));

      if (chartErrors.length) {
        console.error('Chart validation:', chartErrors);
      }

      preview.innerHTML =
        `<h3>${data.title ?? 'Untitled report'}</h3>` +
        renderReportBlocks(blocks);
    } catch (error: unknown) {
      const message =
        error instanceof Error ? error.message : 'Unknown error';
      preview.textContent = `Invalid JSON: ${message}`;
    }
  };

  loadBtn.addEventListener('click', () => {
    editor.value = JSON.stringify(seed, null, 2);
    render();
  });

  saveBtn.addEventListener('click', () => {
    localStorage.setItem(key, editor.value);
  });

  exportBtn.addEventListener('click', () => {
    const blob = new Blob([editor.value], { type: 'application/json' });
    const a = document.createElement('a');
    const parsed = JSON.parse(editor.value) as ReportData;

    a.href = URL.createObjectURL(blob);
    a.download = `${parsed.slug || 'report'}.json`;
    a.click();
    URL.revokeObjectURL(a.href);
  });

  importInput.addEventListener('change', async (event: Event) => {
    const target = event.currentTarget as HTMLInputElement;
    const file = target.files?.[0];
    if (!file) return;

    editor.value = await file.text();
    render();
  });

  editor.addEventListener('input', render);
  editor.value = localStorage.getItem(key) || JSON.stringify(seed, null, 2);
  render();
</script>
